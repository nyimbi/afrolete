[Unit]
Description=AfroLete due background worker
Documentation=/opt/afrolete/backend/README.md
After=network-online.target afrolete-backend.service
Wants=network-online.target

[Service]
Type=oneshot
User=afrolete
WorkingDirectory=/opt/afrolete/backend
EnvironmentFile=/run/pjs/afrolete-backend.env
Environment=AFROLETE_DUE_WORKER_LIMIT=25
Environment=AFROLETE_DUE_WORKER_BILLING_DUNNING_LIMIT=100
Environment=AFROLETE_DUE_WORKER_BILLING_DUNNING_OVERDUE_AFTER_DAYS=0
Environment=AFROLETE_DUE_WORKER_BILLING_DUNNING_REPEAT_AFTER_DAYS=7
Environment=AFROLETE_DUE_WORKER_BILLING_LATE_FEE_LIMIT=100
Environment=AFROLETE_DUE_WORKER_BILLING_LATE_FEE_OVERDUE_AFTER_DAYS=0
Environment=AFROLETE_DUE_WORKER_BILLING_LATE_FEE_REPEAT_AFTER_DAYS=30
Environment=AFROLETE_DUE_WORKER_BILLING_LATE_FEE_FIXED_FEE=0
Environment=AFROLETE_DUE_WORKER_BILLING_LATE_FEE_PERCENTAGE_RATE=2
Environment=AFROLETE_DUE_WORKER_BILLING_LATE_FEE_MAX_FEE=50
Environment=AFROLETE_DUE_WORKER_BILLING_PAYMENT_RETRY_LIMIT=100
Environment=AFROLETE_DUE_WORKER_BILLING_PAYMENT_RETRY_OVERDUE_AFTER_DAYS=0
Environment=AFROLETE_DUE_WORKER_BILLING_PAYMENT_RETRY_REPEAT_AFTER_HOURS=24
Environment=AFROLETE_DUE_WORKER_BILLING_PAYMENT_RETRY_MAX_ATTEMPTS=3
Environment=AFROLETE_DUE_WORKER_BILLING_PAYMENT_RETRY_PROVIDER=billing_provider
Environment=AFROLETE_DUE_WORKER_BILLING_RECURRING_INVOICE_LIMIT=100
Environment=AFROLETE_DUE_WORKER_BILLING_RECURRING_INVOICE_DUE_IN_DAYS=14
Environment=AFROLETE_DUE_WORKER_BILLING_RECURRING_INVOICE_PREFIX=SAAS
Environment=AFROLETE_DUE_WORKER_COMMUNICATION_DIGEST_LIMIT=100
Environment=AFROLETE_DUE_WORKER_COMPLIANCE_RECONCILIATION_LIMIT=100
Environment=AFROLETE_DUE_WORKER_EVENT_TRAVEL_CONSENT_REMINDER_LIMIT=50
Environment=AFROLETE_DUE_WORKER_EVENT_TRAVEL_CONSENT_REMINDER_DUE_WITHIN_HOURS=48
Environment=AFROLETE_DUE_WORKER_EVENT_TRAVEL_CONSENT_REMINDER_REPEAT_AFTER_HOURS=24
Environment=AFROLETE_DUE_WORKER_EVENT_TRAVEL_CONSENT_REMINDER_CHANNEL=email
Environment=AFROLETE_DUE_WORKER_COMMUNICATION_ESCALATION_LIMIT=100
Environment=AFROLETE_DUE_WORKER_COMMUNICATION_ESCALATION_UNRESOLVED_AFTER_MINUTES=15
Environment=AFROLETE_DUE_WORKER_COMMUNICATION_ESCALATION_REPEAT_AFTER_MINUTES=60
Environment=AFROLETE_DUE_WORKER_COMMUNICATION_ESCALATION_LEVEL=2
Environment=AFROLETE_DUE_WORKER_COMMUNICATION_ESCALATION_CHANNEL=sms
Environment=AFROLETE_DUE_WORKER_PERFORMANCE_LIMIT=25
Environment=AFROLETE_DUE_WORKER_PERFORMANCE_FORECAST_VALIDATION_LIMIT=25
Environment=AFROLETE_DUE_WORKER_PERFORMANCE_FORECAST_DRIFT_REPEAT_AFTER_HOURS=24
Environment=AFROLETE_DUE_WORKER_PERFORMANCE_FORECAST_DRIFT_CHANNEL=in_app
Environment=AFROLETE_DUE_WORKER_PERFORMANCE_REVIEW_LIMIT=25
Environment=AFROLETE_DUE_WORKER_PERFORMANCE_REVIEW_HORIZON_HOURS=24
Environment=AFROLETE_DUE_WORKER_PERFORMANCE_REVIEW_REPEAT_AFTER_HOURS=24
Environment=AFROLETE_DUE_WORKER_PERFORMANCE_INJURY_RISK_LIMIT=25
Environment=AFROLETE_DUE_WORKER_PERFORMANCE_INJURY_RISK_THRESHOLD=65
Environment=AFROLETE_DUE_WORKER_PERFORMANCE_INJURY_RISK_REPEAT_AFTER_HOURS=24
Environment=AFROLETE_DUE_WORKER_PERFORMANCE_INJURY_RISK_CHANNEL=in_app
Environment=AFROLETE_DUE_WORKER_WEARABLE_PULL_LIMIT=25
Environment=AFROLETE_DUE_WORKER_WEARABLE_PULL_MAX_PAGES=3
Environment=AFROLETE_DUE_WORKER_WEARABLE_PULL_DEFAULT_RETRY_AFTER_SECONDS=300
Environment=AFROLETE_DUE_WORKER_WEBHOOK_MAX_ATTEMPTS=5
Environment=AFROLETE_DUE_WORKER_EMERGENCY_ESCALATION_LIMIT=50
Environment=AFROLETE_DUE_WORKER_EMERGENCY_ESCALATION_UNRESOLVED_AFTER_MINUTES=15
Environment=AFROLETE_DUE_WORKER_EMERGENCY_ESCALATION_REPEAT_AFTER_MINUTES=15
ExecStart=/opt/afrolete/backend/.venv/bin/python -m app.workers.due \
  --limit ${AFROLETE_DUE_WORKER_LIMIT} \
  --billing-dunning-limit ${AFROLETE_DUE_WORKER_BILLING_DUNNING_LIMIT} \
  --billing-dunning-overdue-after-days ${AFROLETE_DUE_WORKER_BILLING_DUNNING_OVERDUE_AFTER_DAYS} \
  --billing-dunning-repeat-after-days ${AFROLETE_DUE_WORKER_BILLING_DUNNING_REPEAT_AFTER_DAYS} \
  --billing-late-fee-limit ${AFROLETE_DUE_WORKER_BILLING_LATE_FEE_LIMIT} \
  --billing-late-fee-overdue-after-days ${AFROLETE_DUE_WORKER_BILLING_LATE_FEE_OVERDUE_AFTER_DAYS} \
  --billing-late-fee-repeat-after-days ${AFROLETE_DUE_WORKER_BILLING_LATE_FEE_REPEAT_AFTER_DAYS} \
  --billing-late-fee-fixed-fee ${AFROLETE_DUE_WORKER_BILLING_LATE_FEE_FIXED_FEE} \
  --billing-late-fee-percentage-rate ${AFROLETE_DUE_WORKER_BILLING_LATE_FEE_PERCENTAGE_RATE} \
  --billing-late-fee-max-fee ${AFROLETE_DUE_WORKER_BILLING_LATE_FEE_MAX_FEE} \
  --billing-payment-retry-limit ${AFROLETE_DUE_WORKER_BILLING_PAYMENT_RETRY_LIMIT} \
  --billing-payment-retry-overdue-after-days ${AFROLETE_DUE_WORKER_BILLING_PAYMENT_RETRY_OVERDUE_AFTER_DAYS} \
  --billing-payment-retry-repeat-after-hours ${AFROLETE_DUE_WORKER_BILLING_PAYMENT_RETRY_REPEAT_AFTER_HOURS} \
  --billing-payment-retry-max-attempts ${AFROLETE_DUE_WORKER_BILLING_PAYMENT_RETRY_MAX_ATTEMPTS} \
  --billing-payment-retry-provider ${AFROLETE_DUE_WORKER_BILLING_PAYMENT_RETRY_PROVIDER} \
  --billing-recurring-invoice-limit ${AFROLETE_DUE_WORKER_BILLING_RECURRING_INVOICE_LIMIT} \
  --billing-recurring-invoice-due-in-days ${AFROLETE_DUE_WORKER_BILLING_RECURRING_INVOICE_DUE_IN_DAYS} \
  --billing-recurring-invoice-prefix ${AFROLETE_DUE_WORKER_BILLING_RECURRING_INVOICE_PREFIX} \
  --communication-digest-limit ${AFROLETE_DUE_WORKER_COMMUNICATION_DIGEST_LIMIT} \
  --communication-escalation-limit ${AFROLETE_DUE_WORKER_COMMUNICATION_ESCALATION_LIMIT} \
  --communication-escalation-unresolved-after-minutes ${AFROLETE_DUE_WORKER_COMMUNICATION_ESCALATION_UNRESOLVED_AFTER_MINUTES} \
  --communication-escalation-repeat-after-minutes ${AFROLETE_DUE_WORKER_COMMUNICATION_ESCALATION_REPEAT_AFTER_MINUTES} \
  --communication-escalation-level ${AFROLETE_DUE_WORKER_COMMUNICATION_ESCALATION_LEVEL} \
  --communication-escalation-channel ${AFROLETE_DUE_WORKER_COMMUNICATION_ESCALATION_CHANNEL} \
  --compliance-reconciliation-limit ${AFROLETE_DUE_WORKER_COMPLIANCE_RECONCILIATION_LIMIT} \
  --event-travel-consent-reminder-limit ${AFROLETE_DUE_WORKER_EVENT_TRAVEL_CONSENT_REMINDER_LIMIT} \
  --event-travel-consent-reminder-due-within-hours ${AFROLETE_DUE_WORKER_EVENT_TRAVEL_CONSENT_REMINDER_DUE_WITHIN_HOURS} \
  --event-travel-consent-reminder-repeat-after-hours ${AFROLETE_DUE_WORKER_EVENT_TRAVEL_CONSENT_REMINDER_REPEAT_AFTER_HOURS} \
  --event-travel-consent-reminder-channel ${AFROLETE_DUE_WORKER_EVENT_TRAVEL_CONSENT_REMINDER_CHANNEL} \
  --performance-limit ${AFROLETE_DUE_WORKER_PERFORMANCE_LIMIT} \
  --performance-forecast-validation-limit ${AFROLETE_DUE_WORKER_PERFORMANCE_FORECAST_VALIDATION_LIMIT} \
  --auto-alert-performance-forecast-drift \
  --performance-forecast-drift-repeat-after-hours ${AFROLETE_DUE_WORKER_PERFORMANCE_FORECAST_DRIFT_REPEAT_AFTER_HOURS} \
  --performance-forecast-drift-channel ${AFROLETE_DUE_WORKER_PERFORMANCE_FORECAST_DRIFT_CHANNEL} \
  --performance-review-limit ${AFROLETE_DUE_WORKER_PERFORMANCE_REVIEW_LIMIT} \
  --performance-review-horizon-hours ${AFROLETE_DUE_WORKER_PERFORMANCE_REVIEW_HORIZON_HOURS} \
  --performance-review-repeat-after-hours ${AFROLETE_DUE_WORKER_PERFORMANCE_REVIEW_REPEAT_AFTER_HOURS} \
  --performance-injury-risk-limit ${AFROLETE_DUE_WORKER_PERFORMANCE_INJURY_RISK_LIMIT} \
  --performance-injury-risk-threshold ${AFROLETE_DUE_WORKER_PERFORMANCE_INJURY_RISK_THRESHOLD} \
  --performance-injury-risk-repeat-after-hours ${AFROLETE_DUE_WORKER_PERFORMANCE_INJURY_RISK_REPEAT_AFTER_HOURS} \
  --performance-injury-risk-channel ${AFROLETE_DUE_WORKER_PERFORMANCE_INJURY_RISK_CHANNEL} \
  --wearable-pull-limit ${AFROLETE_DUE_WORKER_WEARABLE_PULL_LIMIT} \
  --wearable-pull-max-pages ${AFROLETE_DUE_WORKER_WEARABLE_PULL_MAX_PAGES} \
  --wearable-pull-default-retry-after-seconds ${AFROLETE_DUE_WORKER_WEARABLE_PULL_DEFAULT_RETRY_AFTER_SECONDS} \
  --webhook-max-attempts ${AFROLETE_DUE_WORKER_WEBHOOK_MAX_ATTEMPTS} \
  --emergency-escalation-limit ${AFROLETE_DUE_WORKER_EMERGENCY_ESCALATION_LIMIT} \
  --emergency-escalation-unresolved-after-minutes ${AFROLETE_DUE_WORKER_EMERGENCY_ESCALATION_UNRESOLVED_AFTER_MINUTES} \
  --emergency-escalation-repeat-after-minutes ${AFROLETE_DUE_WORKER_EMERGENCY_ESCALATION_REPEAT_AFTER_MINUTES}
NoNewPrivileges=true
PrivateTmp=true
